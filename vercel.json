{
  "buildCommand": "npm run build && npx prisma generate && npx prisma db push",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    "DATABASE_URL",
    "ADMIN_USERNAME",
    "ADMIN_PASSWORD",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "NEXT_PUBLIC_APP_URL",
    "NODE_ENV"
  ]
}

