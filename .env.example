# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/haram_packages"

# Authentication Credentials (Set these in Vercel environment variables)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# JWT Secret (Generate a secure random string)
JWT_SECRET="your_jwt_secret_key_here_min_32_chars_very_secure_random_string_required"

# API Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# NextAuth Configuration (Optional - if using NextAuth)
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# JWT Token Expiration
JWT_EXPIRES_IN="7d"
